{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "sortImports": true,
  "sortTailwindcss": {
    "functions": ["cn", "clsx", "cva"]
  },
  "ignorePatterns": [".next", "dist", "build", "drizzle", "pnpm-lock.yaml"]
}
